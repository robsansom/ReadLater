---
import AppStoreBadge from './AppStoreBadge.astro';
import { site } from '../config/site';

const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const year = new Date().getFullYear();
const isExternalAppStoreUrl = site.appStoreUrl.startsWith('http');
---

<footer class="relative bg-pouch-ink text-pouch-text border-t border-theme-soft">
  <div class="mx-auto max-w-8xl px-6 sm:px-8 lg:px-10 pt-24 sm:pt-32 pb-12">
    <p class="reveal-eyebrow text-[12px] uppercase tracking-[0.22em] text-pouch-textMuted">A small, considered app</p>
    <h2 class="reveal-lines mt-5 display-section text-[clamp(2.25rem,6vw,5rem)] text-balance">
      <span class="reveal-line"><span>Save the link.&nbsp;<span class="text-dim">Close the tab.</span></span></span>
    </h2>
    <div class="reveal reveal-delay-2 mt-12 sm:mt-16">
      <AppStoreBadge height={56} />
    </div>

    <div class="mt-20 sm:mt-24 pt-10 border-t border-theme-soft grid grid-cols-2 sm:grid-cols-3 gap-8 sm:gap-10 text-[14px]">
      <div>
        <p class="text-pouch-textMuted text-[12px] uppercase tracking-[0.16em]">Product</p>
        <ul class="mt-4 space-y-2.5">
          <li><a href={`${base}#features`} class="hover:text-pouch-red transition-colors">Features</a></li>
          <li>
            <a
              href={site.appStoreUrl}
              target={isExternalAppStoreUrl ? '_blank' : undefined}
              rel={isExternalAppStoreUrl ? 'noopener' : undefined}
              class="hover:text-pouch-red transition-colors"
            >
              Download
            </a>
          </li>
        </ul>
      </div>
      <div>
        <p class="text-pouch-textMuted text-[12px] uppercase tracking-[0.16em]">Company</p>
        <ul class="mt-4 space-y-2.5">
          <li><a href={`${base}support`} class="hover:text-pouch-red transition-colors">Support</a></li>
          <li><a href="mailto:support@readlater.app" class="hover:text-pouch-red transition-colors">Contact</a></li>
        </ul>
      </div>
      <div>
        <p class="text-pouch-textMuted text-[12px] uppercase tracking-[0.16em]">Legal</p>
        <ul class="mt-4 space-y-2.5">
          <li><a href={`${base}privacy`} class="hover:text-pouch-red transition-colors">Privacy</a></li>
          <li><a href={`${base}terms`} class="hover:text-pouch-red transition-colors">Terms</a></li>
        </ul>
      </div>
    </div>

    <div class="mt-12 pt-8 border-t border-theme-soft text-[12.5px] text-pouch-textDim space-y-4">
      <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3">
        <p>&copy; {year} Read Later. Made with care in the UK.</p>
        <p>Read Later is an independent app, not affiliated with Apple Inc.</p>
      </div>
      <p class="max-w-3xl leading-[1.55]">
        Apple, the Apple logo, iPhone and iPad are trademarks of Apple&nbsp;Inc., registered in the U.S. and other countries and regions. App&nbsp;Store is a service mark of Apple&nbsp;Inc.
      </p>
    </div>
  </div>
</footer>
