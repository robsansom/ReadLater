---
import Base from '../../layouts/Base.astro';
import { useTranslations } from '../../i18n/utils';

const t = useTranslations(Astro.currentLocale);
---

<Base
  title={t.privacyPage.metaTitle}
  description={t.privacyPage.metaDescription}
>
  <section class="relative bg-pouch-ink text-pouch-text">
    <div class="mx-auto max-w-3xl px-6 sm:px-8 lg:px-10 pt-20 sm:pt-28 pb-24 sm:pb-32">
      <div>
        <p class="reveal-eyebrow text-[12px] uppercase tracking-[0.24em] text-pouch-textMuted">{t.privacyPage.eyebrow}</p>
        <h1 class="reveal-lines mt-6 sm:mt-7 display-section text-[clamp(2.25rem,6vw,5rem)]">
          <span class="reveal-line"><span>{t.privacyPage.headline}&nbsp;<span class="text-dim">{t.privacyPage.headlineDim}</span></span></span>
        </h1>
        <p class="mt-5 text-pouch-textDim text-[13.5px]">{t.privacyPage.lastUpdated}</p>
      </div>

      <p class="reveal reveal-delay-1 mt-10 text-[17px] leading-[1.6] text-pouch-textSoft">
        {t.privacyPage.intro}
      </p>

      <div class="reveal reveal-delay-2 mt-12 rounded-[24px] bg-pouch-card ring-soft p-7 sm:p-8">
        <p class="text-[12px] uppercase tracking-[0.18em] text-pouch-textMuted">{t.privacyPage.promisesTitle}</p>
        <ul class="mt-5 grid grid-cols-1 sm:grid-cols-2 gap-x-8 gap-y-3 text-[15.5px] leading-[1.5] text-pouch-textSoft">
          {t.privacyPage.promises.map((line) => (
            <li class="flex items-start gap-3">
              <span aria-hidden="true" class="mt-[0.55rem] inline-block w-1.5 h-1.5 rounded-full bg-pouch-red shrink-0"></span>
              <span>{line}</span>
            </li>
          ))}
        </ul>
      </div>

      <div class="mt-14 sm:mt-20 space-y-12">
        {t.privacyPage.sections.map((section, i) => (
          <div class={`reveal reveal-delay-${Math.min(i % 5 + 1, 5)}`}>
            <h2 class="text-[12px] uppercase tracking-[0.18em] text-pouch-textMuted">{section.title}</h2>
            <p class="mt-4 text-[16.5px] leading-[1.65] text-pouch-textSoft">{section.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</Base>
