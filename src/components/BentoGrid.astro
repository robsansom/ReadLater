---
/**
 * Feature bento grid.
 *
 * Six product moments matching the Figma bento (Pouch / node 490-1687).
 * Each tile pairs short copy with an image exported straight from the
 * design file, so the visuals are the real app moments.
 */

type Layout = 'visual-top' | 'stacked' | 'overlay' | 'bottom-flush' | 'split';

interface Feature {
  mobileOrder?: string;
  span: string;
  eyebrow: string;
  title: string;
  body: string;
  accent?: boolean;
  /** Use the larger display-style heading (matches the wide Export tile). */
  largeTitle?: boolean;
  layout: Layout;
  image: {
    src: string;
    alt: string;
    width: number;
    height: number;
    class: string;
  };
}

const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

const features: Feature[] = [
  {
    span: 'md:col-span-3',
    eyebrow: 'Share Extension',
    title: 'Save from anywhere',
    body: 'Save links, articles, videos, PDFs and useful attachments from the apps you already use. One tap, straight to your library.',
    layout: 'visual-top',
    image: {
      src: `${base}images/bento-share-sheet.png`,
      alt: 'iOS share sheet with a saved link and the Read Later action',
      width: 392,
      height: 234,
      class: 'bento-img bento-img--share',
    },
  },
  {
    span: 'md:col-span-3',
    eyebrow: 'Shared Collections',
    title: 'Collect & share what matters',
    body: 'Create and share collections for trips, projects, wishlists and ideas. Keep everything organised across your devices.',
    layout: 'stacked',
    image: {
      src: `${base}images/bento-collections.png`,
      alt: 'Two shared collection cards: Living Room Inspiration and Favourite Restaurants',
      width: 429,
      height: 295,
      class: 'bento-img bento-img--collections',
    },
  },
  {
    span: 'md:col-span-3',
    eyebrow: 'Search',
    title: 'Find the thing fast',
    body: 'Search titles, notes, tags and sources without digging. Find it even when you can\u2019t remember what it was called.',
    accent: true,
    largeTitle: true,
    layout: 'overlay',
    image: {
      src: `${base}images/bento-search-glass.png`,
      alt: '',
      width: 460,
      height: 392,
      class: 'bento-img bento-img--search',
    },
  },
  {
    span: 'md:col-span-3',
    eyebrow: 'Make It Yours',
    title: 'Make every bookmark yours',
    body: 'Rewrite, tag, swap images or generate a better cover.',
    layout: 'stacked',
    image: {
      src: `${base}images/bento-edit-menu.png`,
      alt: 'Edit menu with Edit Thumbnail, Edit Tags, Edit Title and Edit Description actions',
      width: 318,
      height: 222,
      class: 'bento-img bento-img--edit',
    },
  },
  {
    mobileOrder: 'order-6 md:order-none',
    span: 'md:col-span-2',
    eyebrow: 'Privacy',
    title: 'Private by default',
    body: 'No account. No tracking. Your iCloud, your library.',
    layout: 'bottom-flush',
    image: {
      src: `${base}images/bento-privacy-lock.png`,
      alt: 'Red padlock',
      width: 346,
      height: 224,
      class: 'bento-img bento-img--lock',
    },
  },
  {
    mobileOrder: 'order-5 md:order-none',
    span: 'md:col-span-4',
    eyebrow: 'Export',
    title: 'Export anytime. Portable, flexible and yours.',
    body: 'Export your full library, links, notes and collections as Markdown (Obsidian, LLM), CSV (Excel) or JSON.',
    layout: 'split',
    image: {
      src: `${base}images/bento-export-card.png`,
      alt: 'Import and Export settings card with Import bookmarks and Export library options',
      width: 372,
      height: 225,
      class: 'bento-img bento-img--export',
    },
  },
];
---

<section id="features" class="relative bg-pouch-ink text-pouch-text overflow-hidden">
  {/* Contained Dropset-style bento container. Sits in a narrower
      max-width (72rem) than the rest of the page (88rem) so the grid
      reads as a tight, well-proportioned poster of features rather
      than sprawling edge-to-edge. */}
  <div class="mx-auto max-w-6xl px-6 sm:px-8 lg:px-10 pt-24 sm:pt-32 pb-24 sm:pb-32">
    <p class="reveal-eyebrow text-[12px] uppercase tracking-[0.24em] text-pouch-textMuted">
      Features
    </p>

    <h2 class="mt-6 sm:mt-7 display-section text-[clamp(2.25rem,5.5vw,4.5rem)] text-balance max-w-[22ch]">
      Lightweight,&nbsp;<span class="text-dim">on purpose.</span>
    </h2>

    <p class="reveal reveal-delay-2 mt-6 max-w-xl text-[16px] sm:text-[17px] 2xl:text-[19px] leading-[1.55] text-pouch-textSoft">
      Quiet on the outside, deeply capable underneath. The essentials are designed to feel obvious, fast and out of your way.
    </p>

    <div class="mt-12 sm:mt-14 grid grid-cols-1 md:grid-cols-6 gap-3.5 sm:gap-4">
      {features.map((f, i) => {
        const isSplit = f.layout === 'split';
        return (
          <article
            class={[
              'reveal',
              `reveal-delay-${(i % 4) + 1}`,
              'bento-card relative rounded-[24px] p-6 sm:p-7 overflow-hidden min-h-[320px] sm:min-h-[360px]',
              isSplit
                ? 'flex flex-col md:flex-row md:items-center md:gap-8 lg:gap-10'
                : 'flex flex-col',
              f.accent ? 'bg-pouch-red text-white' : 'bento-tile',
              f.mobileOrder ?? '',
              f.span,
            ].join(' ')}
          >
            <div
              class={[
                isSplit ? 'order-2 md:order-1 md:flex-1 md:min-w-0' : '',
                f.layout === 'visual-top' ? 'mt-auto pt-8' : '',
                f.layout === 'overlay' ? 'relative z-10 max-w-[38ch]' : '',
              ].join(' ')}
            >
              <p
                class={[
                  'text-[12px] uppercase tracking-[0.18em]',
                  f.accent ? 'text-white/75' : 'text-pouch-textMuted',
                ].join(' ')}
              >
                {f.eyebrow}
              </p>
              <h3
                class={[
                  'mt-4 font-semibold tracking-tight leading-[1.18]',
                  isSplit || f.largeTitle
                    ? 'text-[clamp(1.65rem,3.2vw,2.4rem)] max-w-[18ch]'
                    : 'text-[clamp(1.25rem,2.2vw,1.55rem)]',
                  f.accent ? 'text-white' : 'text-pouch-text',
                ].join(' ')}
              >
                {f.title}
              </h3>
              <p
                class={[
                  'mt-3 leading-[1.55]',
                  isSplit ? 'text-[15.5px] sm:text-[16px] max-w-[40ch]' : 'text-[14.5px] max-w-[40ch]',
                  f.layout === 'visual-top' ? 'text-[15px] max-w-[52ch] text-pretty' : '',
                  f.accent ? 'text-white/85' : 'text-pouch-textSoft',
                ].join(' ')}
              >
                {f.body}
              </p>
            </div>

            <div
              class={[
                'bento-visual',
                f.layout === 'visual-top' && 'order-first flex justify-center',
                f.layout === 'stacked' && 'mt-8 sm:mt-10 flex-1 flex items-end justify-center',
                f.layout === 'overlay' && 'absolute inset-0',
                f.layout === 'bottom-flush' && 'mt-8 flex-1 flex items-end justify-center -mb-6 sm:-mb-7',
                f.layout === 'split' && 'order-1 md:order-2 mb-8 md:mb-0 md:flex-1 md:min-w-0 md:flex md:justify-end',
              ]
                .filter(Boolean)
                .join(' ')}
            >
              <picture class="contents">
                <source srcset={f.image.src.replace(/\.png$/, '.webp')} type="image/webp" />
                <img
                  src={f.image.src}
                  alt={f.image.alt}
                  class={f.image.class}
                  width={f.image.width}
                  height={f.image.height}
                  loading="lazy"
                  decoding="async"
                />
              </picture>
            </div>
          </article>
        );
      })}
    </div>
  </div>
</section>

<style is:global>
  .bento-visual {
    width: auto;
  }

  .bento-img {
    height: auto;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .bento-card:hover .bento-img {
    transform: translateY(-6px);
  }

  /* Share extension art. The asset is cut square across its top edge
     (the device continues out of frame), so it sits flush against the
     tile's top edge — negative margin cancels the card padding and the
     card's overflow-hidden crops it cleanly. Horizontally centred. */
  .bento-img--share {
    width: min(100%, 430px);
    margin-top: -1.5rem; /* cancels p-6 */
    filter: drop-shadow(0 18px 30px rgba(0, 0, 0, 0.10));
  }
  @media (min-width: 640px) {
    .bento-img--share {
      margin-top: -1.75rem; /* cancels sm:p-7 */
    }
  }

  .bento-img--collections {
    width: min(100%, 429px);
  }
  /* The export carries generous transparent shadow padding; on narrow
     tiles let it bleed slightly so the cards themselves read larger. */
  @media (max-width: 640px) {
    .bento-img--collections {
      width: 114%;
      max-width: none;
    }
  }

  /* Glass magnifier bleeding off the bottom-right corner of the red
     search tile, matching the Figma crop. */
  .bento-img--search {
    position: absolute;
    right: -16px;
    bottom: -16px;
    width: min(92%, 460px);
    max-width: none;
  }
  .bento-card:hover .bento-img--search {
    transform: translateY(-6px) scale(1.02);
  }

  .bento-img--edit {
    width: min(100%, 318px);
  }

  /* Lock sits flush against the tile's bottom edge (the export is
     already cropped at the shackle's keyhole glow). */
  .bento-img--lock {
    width: min(100%, 320px);
  }
  .bento-card:hover .bento-img--lock {
    transform: translateY(-4px);
  }

  .bento-img--export {
    width: min(100%, 372px);
    border-radius: 24px;
    box-shadow: 0 24px 50px -30px rgba(0, 0, 0, 0.5);
  }

  @media (prefers-reduced-motion: reduce) {
    .bento-img,
    .bento-card:hover .bento-img {
      transition: none !important;
      transform: none !important;
    }
  }
</style>
