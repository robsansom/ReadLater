---
/**
 * Feature bento grid.
 *
 * Six product moments matching the Figma bento (Pouch / node 490-1687).
 * Each tile pairs short copy with an image exported straight from the
 * design file, so the visuals are the real app moments.
 */
import { useTranslations } from '../i18n/utils';

const t = useTranslations(Astro.currentLocale);

const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

const bentoLayouts = [
  {
    span: 'md:col-span-3',
    key: 'shareExtension' as const,
    layout: 'visual-top' as const,
    image: {
      src: `${base}images/bento-share-sheet.png`,
      width: 445,
      height: 297,
      class: 'bento-img bento-img--share',
    },
  },
  {
    span: 'md:col-span-3',
    key: 'collections' as const,
    layout: 'stacked' as const,
    image: {
      src: `${base}images/bento-collections.png`,
      width: 429,
      height: 295,
      class: 'bento-img bento-img--collections',
    },
  },
  {
    span: 'md:col-span-3',
    key: 'find' as const,
    accent: true,
    largeTitle: true,
    layout: 'overlay' as const,
    image: {
      src: `${base}images/bento-search-glass.png`,
      width: 460,
      height: 392,
      class: 'bento-img bento-img--search',
    },
  },
  {
    span: 'md:col-span-3',
    key: 'makeItYours' as const,
    layout: 'stacked' as const,
    image: {
      src: `${base}images/bento-edit-menu.png`,
      width: 318,
      height: 222,
      class: 'bento-img bento-img--edit',
    },
  },
  {
    mobileOrder: 'order-6 md:order-none',
    span: 'md:col-span-2',
    key: 'privacy' as const,
    layout: 'bottom-flush' as const,
    image: {
      src: `${base}images/bento-privacy-lock.png`,
      width: 346,
      height: 224,
      class: 'bento-img bento-img--lock',
    },
  },
  {
    mobileOrder: 'order-5 md:order-none',
    span: 'md:col-span-4',
    key: 'export' as const,
    layout: 'split' as const,
    image: {
      src: `${base}images/bento-export-card.png`,
      width: 372,
      height: 225,
      class: 'bento-img bento-img--export',
    },
  },
];
---

<section id="features" class="relative bg-pouch-ink text-pouch-text overflow-hidden">
  {/* Contained Dropset-style bento container. Sits in a narrower
      max-width (72rem) than the rest of the page (88rem) so the grid
      reads as a tight, well-proportioned poster of features rather
      than sprawling edge-to-edge. */}
  <div class="mx-auto max-w-6xl px-6 sm:px-8 lg:px-10 pt-24 sm:pt-32 pb-24 sm:pb-32">
    <p class="reveal-eyebrow text-[12px] uppercase tracking-[0.24em] text-pouch-textMuted">
      {t.bento.eyebrow}
    </p>

    <h2 class="mt-6 sm:mt-7 display-section text-[clamp(2.25rem,6vw,5rem)] text-balance max-w-[22ch]">
      {t.bento.headline}&nbsp;<span class="text-dim">{t.bento.headlineAccent}</span>
    </h2>

    <p class="reveal reveal-delay-2 mt-6 max-w-xl text-[16px] sm:text-[17px] 2xl:text-[19px] leading-[1.55] text-pouch-textSoft">
      {t.bento.body}
    </p>

    <div class="mt-12 sm:mt-14 grid grid-cols-1 md:grid-cols-6 gap-3.5 sm:gap-4">
      {bentoLayouts.map((item, i) => {
        const translation = t.bento[item.key];
        const isSplit = item.layout === 'split';
        return (
          <article
            class={[
              'reveal',
              `reveal-delay-${(i % 4) + 1}`,
              'bento-card relative rounded-[24px] p-6 sm:p-7 overflow-hidden min-h-[320px] sm:min-h-[360px]',
              isSplit
                ? 'flex flex-col md:flex-row md:items-center md:gap-8 lg:gap-10'
                : 'flex flex-col',
              item.accent ? 'bg-pouch-red text-white' : 'bento-tile',
              item.mobileOrder ?? '',
              item.span,
            ].join(' ')}
          >
            <div
              class={[
                isSplit ? 'order-2 md:order-1 md:flex-1 md:min-w-0' : '',
                item.layout === 'visual-top' ? 'mt-auto pt-8' : '',
                item.layout === 'overlay' ? 'relative z-10 max-w-[38ch]' : '',
              ].join(' ')}
            >
              <p
                class={[
                  'text-[12px] uppercase tracking-[0.18em]',
                  item.accent ? 'text-white/75' : 'text-pouch-textMuted',
                ].join(' ')}
              >
                {translation.eyebrow}
              </p>
              <h3
                class={[
                  'mt-4 font-semibold tracking-tight leading-[1.18]',
                  isSplit || ('largeTitle' in item && item.largeTitle)
                    ? 'text-[clamp(1.65rem,3.2vw,2.4rem)] max-w-[18ch]'
                    : 'text-[clamp(1.25rem,2.2vw,1.55rem)]',
                  item.accent ? 'text-white' : 'text-pouch-text',
                ].join(' ')}
              >
                {translation.title}
              </h3>
              <p
                class={[
                  'mt-3 leading-[1.55]',
                  isSplit ? 'text-[15.5px] sm:text-[16px] max-w-[40ch]' : 'text-[14.5px] max-w-[40ch]',
                  item.layout === 'visual-top' ? 'text-[15px] max-w-[52ch] text-pretty' : '',
                  item.accent ? 'text-white/85' : 'text-pouch-textSoft',
                ].join(' ')}
              >
                {translation.body}
              </p>
            </div>

            <div
              class={[
                'bento-visual',
                item.layout === 'visual-top' && 'order-first flex justify-center',
                item.layout === 'stacked' && 'mt-6 sm:mt-7 flex-1 flex items-end justify-center',
                item.layout === 'overlay' && 'absolute inset-0',
                item.layout === 'bottom-flush' && 'mt-8 flex-1 flex items-end justify-center -mb-6 sm:-mb-7',
                item.layout === 'split' && 'order-1 md:order-2 mb-8 md:mb-0 md:flex-1 md:min-w-0 md:flex md:justify-end',
              ]
                .filter(Boolean)
                .join(' ')}
            >
              <picture class="contents">
                <source srcset={item.image.src.replace(/\.png$/, '.webp')} type="image/webp" />
                <img
                  src={item.image.src}
                  alt={translation.alt}
                  class={item.image.class}
                  width={item.image.width}
                  height={item.image.height}
                  loading="lazy"
                  decoding="async"
                />
              </picture>
            </div>
          </article>
        );
      })}
    </div>
  </div>
</section>

<style is:global>
  .bento-visual {
    width: auto;
  }

  .bento-img {
    height: auto;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .bento-card:hover .bento-img {
    transform: translateY(-6px);
  }

  /* Share extension art. Keep the cropped top flush with the tile, but
     inset the sides slightly so the device has a little breathing room. */
  .bento-img--share {
    width: 94%;
    max-width: none;
    margin: -1.5rem auto 0;
    filter: drop-shadow(0 18px 30px rgba(0, 0, 0, 0.10));
  }
  @media (min-width: 640px) {
    .bento-img--share {
      margin-top: -1.75rem;
    }
  }

  .bento-img--collections {
    /* Slightly tighter cap keeps the first bento row shorter, which in
       turn trims the empty band under the share-sheet device next door. */
    width: min(100%, 396px);
  }
  /* The export carries generous transparent shadow padding; on narrow
     tiles let it bleed slightly so the cards themselves read larger. */
  @media (max-width: 640px) {
    .bento-img--collections {
      width: 114%;
      max-width: none;
    }
  }

  /* Glass magnifier bleeding off the bottom-right corner of the red
     search tile, matching the Figma crop. */
  .bento-img--search {
    position: absolute;
    right: -16px;
    bottom: -16px;
    width: min(92%, 460px);
    max-width: none;
  }
  .bento-card:hover .bento-img--search {
    transform: translateY(-6px) scale(1.02);
  }

  .bento-img--edit {
    width: min(100%, 318px);
  }

  /* Lock sits flush against the tile's bottom edge (the export is
     already cropped at the shackle's keyhole glow). */
  .bento-img--lock {
    width: min(100%, 320px);
  }
  .bento-card:hover .bento-img--lock {
    transform: translateY(-4px);
  }

  .bento-img--export {
    width: min(100%, 372px);
    border-radius: 24px;
    box-shadow: 0 24px 50px -30px rgba(0, 0, 0, 0.5);
  }

  @media (prefers-reduced-motion: reduce) {
    .bento-img,
    .bento-card:hover .bento-img {
      transition: none !important;
      transform: none !important;
    }
  }
</style>
