---
/**
 * PartOfIphone — system-integration section (Spotlight, Siri, Shortcuts).
 * Copy is canonical from Docs/MESSAGING_KIT.md §4–5 in the app repo:
 * the website never leads the app, and these features have shipped.
 */
import { useTranslations } from '../i18n/utils';

const t = useTranslations(Astro.currentLocale);
---

<section class="relative bg-pouch-ink text-pouch-text overflow-hidden">
  <div class="mx-auto max-w-6xl px-6 sm:px-8 lg:px-10 pt-24 sm:pt-32 pb-24 sm:pb-32">
    <p class="reveal-eyebrow text-[12px] uppercase tracking-[0.24em] text-pouch-textMuted">
      {t.integration.eyebrow}
    </p>

    <h2 class="mt-6 sm:mt-7 display-section text-[clamp(2.25rem,6vw,5rem)] text-balance max-w-[22ch]">
      {t.integration.headline}&nbsp;<span class="text-dim">{t.integration.headlineAccent}</span>
    </h2>

    <p class="reveal reveal-delay-2 mt-6 max-w-2xl text-[16px] sm:text-[17px] 2xl:text-[19px] leading-[1.55] text-pouch-textSoft">
      {t.integration.body}
    </p>

    <div class="mt-12 sm:mt-14 grid grid-cols-1 md:grid-cols-3 gap-3.5 sm:gap-4">
      <article class="reveal reveal-delay-1 bento-card bento-tile rounded-[24px] p-6 sm:p-7 flex flex-col">
        <span class="system-glyph" aria-hidden="true">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round">
            <circle cx="10.5" cy="10.5" r="6.5" />
            <path d="M15.5 15.5 L20.5 20.5" />
          </svg>
        </span>
        <p class="mt-5 text-[12px] uppercase tracking-[0.18em] text-pouch-textMuted">{t.integration.spotlight.eyebrow}</p>
        <h3 class="mt-3 font-semibold tracking-tight leading-[1.18] text-[clamp(1.25rem,2.2vw,1.55rem)] text-pouch-text">
          {t.integration.spotlight.title}
        </h3>
        <p class="mt-3 leading-[1.55] text-[14.5px] max-w-[40ch] text-pouch-textSoft">
          {t.integration.spotlight.body}
        </p>
      </article>

      <article class="reveal reveal-delay-2 bento-card bento-tile rounded-[24px] p-6 sm:p-7 flex flex-col">
        <span class="system-glyph" aria-hidden="true">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round">
            <path d="M3 10 v4 M7.5 6.5 v11 M12 3.5 v17 M16.5 6.5 v11 M21 10 v4" />
          </svg>
        </span>
        <p class="mt-5 text-[12px] uppercase tracking-[0.18em] text-pouch-textMuted">{t.integration.siri.eyebrow}</p>
        <h3 class="mt-3 font-semibold tracking-tight leading-[1.18] text-[clamp(1.25rem,2.2vw,1.55rem)] text-pouch-text">
          {t.integration.siri.title}
        </h3>
        <p class="mt-3 leading-[1.55] text-[14.5px] max-w-[40ch] text-pouch-textSoft">
          {t.integration.siri.body}
        </p>
      </article>

      <article class="reveal reveal-delay-3 bento-card bento-tile rounded-[24px] p-6 sm:p-7 flex flex-col">
        <span class="system-glyph" aria-hidden="true">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linejoin="round">
            <rect x="3.5" y="3.5" width="13" height="13" rx="3.5" />
            <path d="M20.5 8.5 v8.5 a3.5 3.5 0 0 1 -3.5 3.5 H8.5" />
          </svg>
        </span>
        <p class="mt-5 text-[12px] uppercase tracking-[0.18em] text-pouch-textMuted">{t.integration.shortcuts.eyebrow}</p>
        <h3 class="mt-3 font-semibold tracking-tight leading-[1.18] text-[clamp(1.25rem,2.2vw,1.55rem)] text-pouch-text">
          {t.integration.shortcuts.title}
        </h3>
        <div class="mt-4 flex flex-wrap gap-1.5">
          {t.integration.shortcuts.actions.map((action) => (
            <span class="system-action-pill">{action}</span>
          ))}
        </div>
      </article>
    </div>
  </div>
</section>
