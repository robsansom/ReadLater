---
/**
 * Testimonials — Dropset-style "What other people think." block.
 *
 * Restraint over chrome: no card backgrounds, no rings, no glass.
 * Just stars, a punchy title, a short body, and a quiet date byline.
 * Sits in a tighter centred container (max-w-6xl) so it reads as a
 * tight, magazine-style review column rather than a wall of cards.
 *
 * Each entry is placeholder copy until real reviews are gathered.
 * To swap in a real review, replace the strings in `testimonials`
 * below and remove the `isPlaceholder: true` flag.
 */

interface Testimonial {
  /** Star rating from 1–5. Defaults to 5 if omitted. */
  stars?: number;
  /** Short bold review title — think App Store review headline. */
  title: string;
  /** Body of the review. Plain text; keep ~2–3 sentences. */
  body: string;
  /** Free-form date label, e.g. "September 2026" or "Early access tester". */
  date: string;
  /** Set to `true` while the entry is still placeholder copy. */
  isPlaceholder?: boolean;
}

const testimonials: Testimonial[] = [
  {
    title: 'Finally, a Read-Later app that feels Apple-made.',
    body:
      'I’ve cycled through every read-later app on the App Store. Read Later is the first one that actually feels like it belongs on iOS - quiet, fast, and out of the way. The Share Sheet save is one tap, and search just works.',
    date: 'Early access feedback',
    isPlaceholder: true,
  },
  {
    title: 'No account, no nonsense, no tracking.',
    body:
      'I love that there’s nothing to sign up for. I open the app, hit share from Safari, and that’s it. My library is on my devices, in my iCloud, and that’s where it stays.',
    date: 'Early access feedback',
    isPlaceholder: true,
  },
  {
    title: 'Sharing a collection made trip planning easier.',
    body:
      'I sent our holiday collection with restaurants, viewpoints and things to do. The other person added a copy to their own library, so we each had the list ready on our phones.',
    date: 'Early access feedback',
    isPlaceholder: true,
  },
];
---

<section id="testimonials" class="relative bg-pouch-ink text-pouch-text overflow-hidden">
  <div class="mx-auto max-w-6xl px-6 sm:px-8 lg:px-10 pt-24 sm:pt-32 pb-24 sm:pb-32">
    <p class="reveal-eyebrow text-[12px] uppercase tracking-[0.24em] text-pouch-textMuted">
      Reviews
    </p>

    <h2 class="mt-6 sm:mt-7 display-section text-[clamp(2.25rem,6vw,5rem)] text-balance max-w-[18ch]">
      What other&nbsp;<span class="text-dim">people think.</span>
    </h2>

    <p class="reveal reveal-delay-2 mt-6 max-w-xl text-[16px] sm:text-[17px] 2xl:text-[19px] leading-[1.55] text-pouch-textSoft">
      Reviews from early-access testers and App Store customers. If you&rsquo;d like yours featured, email us. We&rsquo;re collecting them as the app rolls out.
    </p>

    <div class="mt-16 sm:mt-20 grid grid-cols-1 md:grid-cols-3 gap-x-10 lg:gap-x-14 gap-y-14">
      {testimonials.map((t, i) => (
        <article
          class={`reveal reveal-delay-${(i % 3) + 1} testimonial`}
          data-placeholder={t.isPlaceholder ? 'true' : undefined}
        >
          <span class="testimonial-stars" aria-label={`${t.stars ?? 5} star rating`}>
            {Array.from({ length: t.stars ?? 5 }).map(() => (
              <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M12 2l2.95 6.32 6.97.65-5.27 4.74 1.57 6.84L12 17.27 5.78 20.55l1.57-6.84L2.08 8.97l6.97-.65z" />
              </svg>
            ))}
          </span>

          <h3 class="mt-6 text-[18px] sm:text-[19px] font-semibold tracking-tight leading-[1.3] text-pouch-text">
            {t.title}
          </h3>

          <p class="mt-3 text-[15px] leading-[1.6] text-pouch-textSoft">
            {t.body}
          </p>

          <p class="mt-6 text-[12.5px] text-pouch-textMuted">
            {t.date}{t.isPlaceholder ? ' · Placeholder' : ''}
          </p>
        </article>
      ))}
    </div>
  </div>
</section>
