---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import Showcase from '../components/Showcase.astro';
import TabletShowcase from '../components/TabletShowcase.astro';
import SplitHeadline from '../components/SplitHeadline.astro';
import BentoGrid from '../components/BentoGrid.astro';
import PartOfIphone from '../components/PartOfIphone.astro';
---

<Base
  title="Read Later - Save anything. Find everything."
  description="A beautifully simple place for the articles, videos, recipes and ideas you want to find again. For iPhone and iPad."
>
  <Hero />

  <Showcase
    eyebrow="Quick save"
    headline="Save it now,"
    headlineAccent="find it later."
    image="bookmark-cards"
    alt="The Read Later iPhone app showing the dark-mode library of saved articles and ideas, with photos, titles and tags."
    body="One tap from any app saves it with its title, cover and source - search, filter and find your way back, fast."
    device="right"
    themeImageMode="dark"
  />

  {/* New "Cards" showcase. Sits inside the dark stretch (before the
      theme sentinel flips the page to light) so it keeps the same dark
      tone as Bookmarks above it, with the device on the opposite side
      to create visual rhythm. */}
  <Showcase
    eyebrow="Your library"
    headline="Every save."
    headlineAccent="Uniquely yours."
    image="card-screens"
    alt="The Read Later iPhone app showing detail cards for different saved items, cycling through recipes, travel planning, walks, design ideas, and restaurants."
    body="Everything you save lands as a full card with its cover image, source and notes. Edit the title, swap the cover, retag it, or regenerate it with Apple Intelligence - every part of the card is yours to shape."
    device="left"
    themeImageMode="dark"
  />

  {/* Tablet moment. The `#theme-sentinel` sits at the vertical midpoint
      of the iPad image so the page-wide theme flip and the iPad screen
      cross-fade land in the same beat. */}
  <TabletShowcase
    eyebrow="iPad"
    headline="Your library,"
    headlineAccent="expanded."
    body="Designed for iPad from the start. See more of your library at once, with collections, previews and your saves arranged for the wider screen."
    imageDark="ipad-dark"
    imageLight="ipad-light"
    altDark="The Read Later iPad app in dark mode, showing a Collections home with Quick Jump shortcuts, Recently Added cards and Favorites."
    altLight="The Read Later iPad app in light mode, showing a Collections home with Quick Jump shortcuts, Recently Added cards and Favorites."
  />

  <Showcase
    eyebrow="Collections"
    headline="Share"
    headlineAccent="collections."
    image="collection-cards"
    alt="Three collection share cards fanning out, showing how saved items can be grouped and sent to someone else."
    body="Group your saves into trips, projects, wishlists or moodboards. Share a snapshot of a whole collection so someone else can add their own copy to Read Later."
    device="right"
    themeImageMode="light"
  />

  <SplitHeadline
    eyebrow="Privacy"
    first="Private,"
    second="by default."
    body="No account. No tracking. No third-party SDKs. What happens in Read Later stays on your iPhone, your iPad, and your own iCloud."
  />

  <BentoGrid />

  <PartOfIphone />

  {/* Scroll-triggered global theme inversion. Toggles `is-light` on
      <html> when #theme-sentinel above crosses the viewport midline.
      Lives inside <Base> so the script is rendered inside <body>. */}
  <script is:inline>
    (() => {
      const root = document.documentElement;
      root.classList.add('boot');

      const init = () => {
        const sentinel = document.getElementById('theme-sentinel');
        if (!sentinel) {
          root.classList.remove('boot');
          return;
        }

        const update = () => {
          const trigger = window.innerHeight * 0.5;
          const y = sentinel.getBoundingClientRect().top;
          root.classList.toggle('is-light', y < trigger);

          const header = document.getElementById('site-header');
          if (header) {
            const sampleY = Math.min(header.getBoundingClientRect().bottom + 2, window.innerHeight - 1);
            const surface = document.elementFromPoint(window.innerWidth / 2, sampleY)?.closest('section, footer');
            const surfaceIsLight = root.classList.contains('is-light')
              && surface?.classList.contains('bg-pouch-ink');
            root.classList.toggle('header-on-light', Boolean(surfaceIsLight));
            root.classList.toggle('header-on-dark', !surfaceIsLight);
          }
        };

        update();
        // Clear the boot guard on the next frame so subsequent flips animate.
        requestAnimationFrame(() => {
          requestAnimationFrame(() => root.classList.remove('boot'));
        });

        window.addEventListener('scroll', update, { passive: true });
        window.addEventListener('resize', update);
      };

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init);
      } else {
        init();
      }
    })();
  </script>
</Base>
