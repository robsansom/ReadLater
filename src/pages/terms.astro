---
import Base from '../layouts/Base.astro';

const lastUpdated = '21 May 2026';
const supportEmail = 'support@readlater.app';
const appleEula = 'https://www.apple.com/legal/internet-services/itunes/dev/stdeula/';
const appleMediaServices = 'https://www.apple.com/legal/internet-services/itunes/';
const reportAProblem = 'https://reportaproblem.apple.com';

/**
 * Plain-language summary surfaced at the top of the page (the
 * "TL;DR" pattern used by Readwise and other consumer-friendly
 * legal pages). The binding language is the sections array below.
 */
const tldr = [
  'Read Later is licensed to you for personal use on your Apple devices.',
  'The free tier covers 50 saves; Plus is \u00a312.99/year or \u00a334.99 once for life.',
  'Apple takes payment, handles refunds and manages your subscription.',
  'Your saved content is yours - we don\u2019t access it, claim it or train AI on it.',
  'These terms are governed by the laws of England & Wales.',
];

const sections = [
  {
    title: '1. About these terms',
    body: `These terms apply when you download or use the Read Later iOS app ("Read Later", the "App"). The App is published by an independent UK-based developer ("we", "us"). By using Read Later, you agree to these terms together with Apple\u2019s Licensed Application End User Licence Agreement (the "Apple EULA"). They are written in plain English on purpose.`,
  },
  {
    title: '2. The licence',
    body: `Read Later is licensed (not sold) to you for personal, non-commercial use on any Apple device you own or control, on the terms of the Apple EULA. Where these terms add to the Apple EULA - for example on our intellectual property, refunds, or the law that governs disputes between us - these terms apply alongside it.`,
    link: { label: 'Read the Apple Standard EULA', href: appleEula },
  },
  {
    title: '3. Free and Plus',
    body: `Read Later is free to start. The free tier lets you save up to 50 items, with full search, tags, notes and iCloud sync. Read Later Plus unlocks unlimited saves, unlimited Collections, and the ability to share Collections with other Apple users through iCloud.`,
  },
  {
    title: '4. Subscriptions and one-time purchase',
    body: `Plus is offered two ways: a \u00a312.99/year auto-renewing subscription, or a \u00a334.99 one-time lifetime purchase. Payment is taken by Apple through your Apple ID at the point of purchase, and the same Apple ID is charged for renewals. Subscriptions automatically renew at the same price for the same term unless auto-renew is turned off at least 24 hours before the end of the current period. The renewal charge is taken within 24 hours before the end of the current period. You can manage or cancel a subscription at any time from iOS Settings \u203a your name \u203a Subscriptions. Lifetime is a single payment that does not recur. Any free trial period (if offered) automatically converts into a paid subscription at the end of the trial unless cancelled at least 24 hours before the trial ends; any unused portion of a free trial is forfeited when you buy a subscription.`,
  },
  {
    title: '5. Refunds',
    body: `All purchases of Read Later are processed by Apple under the Apple Media Services Terms. Apple, not us, handles refunds. You can request a refund via reportaproblem.apple.com or your Apple ID purchase history. We have no power to issue refunds directly and we do not store your payment details.`,
    link: { label: 'Request an Apple refund', href: reportAProblem },
  },
  {
    title: '6. Price changes',
    body: `Prices may change over time. If a recurring subscription price changes, Apple will notify you and ask for renewed consent before the new price takes effect, as required by the Apple Media Services Terms and applicable consumer law. You may cancel at any time before that change applies.`,
    link: { label: 'Apple Media Services Terms', href: appleMediaServices },
  },
  {
    title: '7. Your content is yours',
    body: `Everything you save in Read Later - links, tags, notes, the structure of your Collections - belongs to you. We claim no licence over it and we never access it. You are responsible for what you choose to save: please don\u2019t use Read Later to save or share material that is illegal, that infringes someone else\u2019s rights, or that is intended to harass other people. Respect the terms of the websites whose content you save.`,
  },
  {
    title: '8. Sync and sharing',
    body: `If you are signed in to iCloud, Read Later syncs your data through Apple\u2019s CloudKit using your own iCloud container. We do not operate the sync servers and we have no access to that data. Sharing a Collection uses CloudKit Sharing: you choose who to invite, and you can stop sharing at any time from inside the App. The participants you invite see only the Collection you share with them.`,
  },
  {
    title: '9. Acceptable use',
    body: `Please don\u2019t (a) try to reverse engineer, decompile or modify Read Later beyond what the law expressly permits or what the Apple EULA allows; (b) attempt to bypass App Store purchase or entitlement checks; (c) use Sharing to spam, harass, or distribute illegal content; or (d) use Read Later in any way that interferes with anyone else\u2019s use of it. We may suspend access for a serious breach.`,
  },
  {
    title: '10. Third-party content',
    body: `Read Later displays previews of, and opens, links from third-party websites and services. We don\u2019t host, modify, screen or endorse that content, and we aren\u2019t responsible for its accuracy, legality, availability or terms. Your use of any linked site is subject to that site\u2019s own rules.`,
  },
  {
    title: '11. Our intellectual property',
    body: `The Read Later name, design, icons, source code, and brand are owned by us. The licence in section 2 does not transfer any rights in them to you. We don\u2019t mind if you mention the App or link to readlater.app in reviews, articles or social posts - please just don\u2019t imply that we endorse or sponsor your work without our written permission.`,
  },
  {
    title: '12. Apple\u2019s role (Apple-Enabled Software)',
    body: `Read Later is distributed through Apple\u2019s App Store, which adds the following terms required by Apple:`,
    bullets: [
      'These terms are entered into between you and us, not Apple. Apple is not a party to them and has no responsibility for the App or its content.',
      'We (not Apple) are solely responsible for the App, its content and any maintenance or support. Apple has no obligation to provide any maintenance or support in relation to the App.',
      'In the event of any failure of the App to conform to any applicable warranty, you may notify Apple, and Apple will refund the purchase price of the App to you (if any). To the maximum extent permitted by law, Apple has no other warranty obligation whatsoever in relation to the App.',
      'We (not Apple) are responsible for addressing any claims relating to the App or your possession or use of it, including product-liability claims, claims that the App fails to conform to any applicable legal or regulatory requirement, and claims arising under consumer-protection or privacy law.',
      'We (not Apple) are responsible for the investigation, defence, settlement and discharge of any third-party intellectual-property infringement claims relating to the App.',
      'You represent and warrant that (a) you are not located in a country subject to a US Government embargo, or that has been designated by the US Government as a "terrorist supporting" country, and (b) you are not listed on any US Government list of prohibited or restricted parties.',
      'Apple and Apple\u2019s subsidiaries are third-party beneficiaries of these terms and, upon your acceptance, will have the right (and will be deemed to have accepted the right) to enforce them against you as a third-party beneficiary.',
    ],
  },
  {
    title: '13. Disclaimers',
    body: `Read Later is provided "as is" and "as available". To the maximum extent permitted by law, we disclaim all warranties, conditions and representations not expressly stated here, including any warranty that the App will be uninterrupted, error-free, or that metadata fetched from third-party sites will be accurate. Nothing in these terms removes or limits any non-excludable rights you have under the UK Consumer Rights Act 2015 or similar consumer-protection laws.`,
  },
  {
    title: '14. Limitation of liability',
    body: `To the maximum extent permitted by law, our total liability to you for any claim arising out of or relating to these terms or your use of Read Later is limited to the greater of (a) the amount you paid us through the App Store in the 12 months before the claim or (b) £100. We are not liable for indirect, consequential or incidental loss, including lost data, lost profits or lost goodwill. Nothing in these terms excludes or limits our liability for death or personal injury caused by our negligence, for fraud, or for any liability that cannot legally be excluded.`,
  },
  {
    title: '15. Termination',
    body: `These terms apply for as long as you use the App. You can stop using Read Later at any time by deleting it. We may suspend access if you materially breach these terms. Your saved content remains on your device and in your own iCloud regardless - we have no power to delete it from there.`,
  },
  {
    title: '16. Changes',
    body: `We may update these terms from time to time. The date at the top of this page will reflect any change, and material changes will be flagged in the App\u2019s release notes or on the website. Continued use of Read Later after a change indicates acceptance of the updated terms.`,
  },
  {
    title: '17. Governing law and jurisdiction',
    body: `These terms are governed by the laws of England & Wales. Disputes will be heard in the courts of England & Wales, except that consumers may bring claims in the courts of their place of residence to the extent required by local law. We don\u2019t require arbitration and we don\u2019t waive your right to bring small-claims or class actions where that right is protected by law.`,
  },
  {
    title: '18. Contact',
    body: `Questions about these terms? Email ${supportEmail}. A UK postal address is available on request for formal correspondence.`,
  },
];
---

<Base
  title="Terms of Use - Read Later"
  description="The plain-English terms that apply when you download or use the Read Later iOS app."
>
  <section class="relative bg-pouch-ink text-pouch-text">
    <div class="mx-auto max-w-3xl px-6 sm:px-8 lg:px-10 pt-20 sm:pt-28 pb-24 sm:pb-32">
      <div>
        <p class="reveal-eyebrow text-[12px] uppercase tracking-[0.24em] text-pouch-textMuted">Legal</p>
        <h1 class="reveal-lines mt-5 display-section text-[clamp(2.25rem,6vw,5rem)]">
          <span class="reveal-line"><span>Terms&nbsp;<span class="text-dim">of Use.</span></span></span>
        </h1>
        <p class="mt-5 text-pouch-textDim text-[13.5px]">Last updated: {lastUpdated}</p>
      </div>

      <p class="reveal reveal-delay-1 mt-10 text-[17px] leading-[1.6] text-pouch-textSoft">
        These terms apply when you download or use the Read Later iOS app (&ldquo;Read Later&rdquo;, &ldquo;we&rdquo;, &ldquo;us&rdquo;). By using Read Later you agree to them, together with Apple&rsquo;s Standard EULA. They are written in plain English on purpose.
      </p>

      <div class="reveal reveal-delay-2 mt-12 rounded-[24px] bg-pouch-card ring-soft p-7 sm:p-8">
        <p class="text-[12.5px] uppercase tracking-[0.2em] text-pouch-textMuted">In short</p>
        <ul class="mt-5 space-y-3 text-[15.5px] leading-[1.5] text-pouch-textSoft">
          {tldr.map((line) => (
            <li class="flex items-start gap-3">
              <span aria-hidden="true" class="mt-[0.55rem] inline-block w-1.5 h-1.5 rounded-full bg-pouch-red shrink-0"></span>
              <span>{line}</span>
            </li>
          ))}
        </ul>
      </div>

      <div class="mt-14 sm:mt-20 space-y-12">
        {sections.map((section, i) => (
          <div class={`reveal reveal-delay-${Math.min(i % 5 + 1, 5)}`}>
            <h2 class="text-[12.5px] uppercase tracking-[0.18em] text-pouch-textMuted">{section.title}</h2>
            <p class="mt-4 text-[16.5px] leading-[1.65] text-pouch-textSoft">{section.body}</p>
            {section.bullets && (
              <ul class="mt-4 space-y-3 text-[16px] leading-[1.6] text-pouch-textSoft list-disc list-outside pl-5 marker:text-pouch-red/60">
                {section.bullets.map((b) => <li>{b}</li>)}
              </ul>
            )}
            {section.link && (
              <a
                href={section.link.href}
                class="mt-3 inline-flex items-center gap-1 text-[14px] text-pouch-red hover:opacity-90 transition-opacity"
                target="_blank"
                rel="noopener noreferrer"
              >
                {section.link.label}
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <line x1="7" y1="17" x2="17" y2="7"/>
                  <polyline points="7 7 17 7 17 17"/>
                </svg>
              </a>
            )}
          </div>
        ))}
      </div>
    </div>
  </section>
</Base>
